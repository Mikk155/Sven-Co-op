{
    // Whatever players should collide with allied npcs.
    "npc_clip": false,

    // Allow boosting by jumping over a player / npc
    "player_boost": true,

    // Whatever projectiles (rockets, spores, bolts etc) can clip to allies
    // Disabling this will disable the ShouldCollideHook
    "projectiles_clip": false,

    "client_prediction":
    {
        // NOTE: set to false and will considerably improve performance.
        "active": true,

        // rendermode var for intersecting entities.
        "rendermode": 4,
        // renderamt var for intersecting entities.
        "renderamt": 100,

        // Completelly hide intersecting entities. (ignore render settings)
        "invisible": false
    },

    // Should this json file be parsed every map change?
    "reload": false,

    // List of maps that this plugin should be disabled.
    // Supports the wildcard "*" as suffix and prefix
    "map_blacklist":
    [
        "bts_rc",
        "of*"
    ]
}
