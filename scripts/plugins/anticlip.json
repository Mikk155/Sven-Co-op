// Anti Clip configuration
{
    // Whatever players should collide with allied npcs.
    "npc_clip": false,

    // Allow boosting by jumping over a player
    "player_boost": true,

    // Whatever projectiles (rockets, spores, bolts etc) can clip to allies
    "projectiles_clip": false,

    // Completelly hide intersecting entities. if this is false the next option has no effect.
    "cliper_invisible": false,

    // rendermode var for intersecting entities.
    "cliper_rendermode": 4,

    // renderamt var for intersecting entities.
    "cliper_renderamt": 100,

    // NOTE: Setting cliper_invisible to false and cliper_rendermode to 0 will considerably improve performance.
    // At the cost of fully visible players & clients "stomping" entities for a moment since no client-prediction

    "map_blacklist":
    [
        "hl_c05_a1",
        "hl_c05_a2"
    ]
}
