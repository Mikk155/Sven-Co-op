{
    "configurations": [
        {
            "name": "aslp",
            "includePath": [
                "${workspaceFolder}/src/aslp/**",
                "${workspaceFolder}/external/json/single_include/**",
                "${workspaceFolder}/external/fmt/include/**"
            ],
            "defines": [
                "_DEBUG",
                "NDEBUG", // Release
                "LINUX",
                "_LINUX",
                "_WINDOWS",
                "WIN32",
                "AS_GENERATE_DOCUMENTATION"
            ],
            "windowsSdkVersion": "10.0.19041.0",
            "compilerPath": "cl.exe",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "configurationProvider": "ms-vscode.cmake-tools"
        },
        {
            "name": "GenerateASPredefined",
            "includePath": [
                "${workspaceFolder}/test/GenerateASPredefined/**",
                "${workspaceFolder}/src/aslp/**",
                "${workspaceFolder}/external/json/single_include/**",
                "${workspaceFolder}/external/fmt/include/**"
            ],
            "defines": [
                "_DEBUG",
                "NDEBUG", // Release
                "LINUX",
                "_LINUX",
                "_WINDOWS",
                "WIN32",
                "AS_GENERATE_DOCUMENTATION",
                "EXTERNAL_PROGRAM_TEST"
            ],
            "windowsSdkVersion": "10.0.19041.0",
            "compilerPath": "cl.exe",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "configurationProvider": "ms-vscode.cmake-tools"
        }
    ],
    "version": 4
}